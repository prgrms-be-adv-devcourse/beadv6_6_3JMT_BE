<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
  "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN",
  "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  PromptHub Checkstyle 설정
  목적: 네이밍 규칙 최소한만 적용 (빌드 실패 없이 경고만)

  적용 방법:
  1. 이 파일을 config/checkstyle/prompthub-checkstyle-rules.xml 에 저장
  2. build.gradle 설정 추가 (prompthub-build.gradle 참고)
  3. ./gradlew checkstyleMain 으로 검사 실행
-->

<module name="Checker">

  <!-- 경고만 출력, 빌드 실패 안함 -->
  <property name="severity" value="warning"/>

  <!-- 검사할 파일 -->
  <property name="fileExtensions" value="java"/>

  <module name="TreeWalker">

    <!-- ===================== -->
    <!-- 네이밍 규칙           -->
    <!-- ===================== -->

    <!-- 클래스명: PascalCase -->
    <module name="TypeName">
      <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
      <message key="name.invalidPattern"
        value="클래스명 ''{0}'' 은 PascalCase 여야 합니다. 예: UserService, ProductController"/>
    </module>

    <!-- 메서드명: camelCase -->
    <module name="MethodName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
      <message key="name.invalidPattern"
        value="메서드명 ''{0}'' 은 camelCase 여야 합니다. 예: getUserList, createOrder"/>
    </module>

    <!-- 변수명: camelCase -->
    <module name="LocalVariableName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
      <message key="name.invalidPattern"
        value="변수명 ''{0}'' 은 camelCase 여야 합니다. 예: userName, productId"/>
    </module>

    <!-- 멤버변수명: camelCase -->
    <module name="MemberName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
      <message key="name.invalidPattern"
        value="멤버변수명 ''{0}'' 은 camelCase 여야 합니다. 예: sellerId, totalAmount"/>
    </module>

    <!-- 파라미터명: camelCase -->
    <module name="ParameterName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
      <message key="name.invalidPattern"
        value="파라미터명 ''{0}'' 은 camelCase 여야 합니다. 예: userId, productId"/>
    </module>

    <!-- 상수명: UPPER_SNAKE_CASE -->
    <module name="ConstantName">
      <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
      <message key="name.invalidPattern"
        value="상수명 ''{0}'' 은 UPPER_SNAKE_CASE 여야 합니다. 예: MAX_RETRY_COUNT, BASE_URL"/>
    </module>

    <!-- 패키지명: 소문자만 -->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
      <message key="name.invalidPattern"
        value="패키지명 ''{0}'' 은 소문자만 사용해야 합니다. 예: com.prompthub.product"/>
    </module>

    <!-- ===================== -->
    <!-- import 규칙           -->
    <!-- ===================== -->

    <!-- 와일드카드 import 금지 -->
    <module name="AvoidStarImport">
      <message key="import.avoidStar"
        value="와일드카드 import 금지: ''{0}'' → 클래스명을 직접 명시하세요."/>
    </module>

    <!-- 사용하지 않는 import 금지 -->
    <module name="UnusedImports">
      <message key="import.unused"
        value="사용하지 않는 import: ''{0}'' → 삭제하세요."/>
    </module>

    <!-- ===================== -->
    <!-- 코드 품질             -->
    <!-- ===================== -->

    <!-- 빈 catch 블록 금지 -->
    <module name="EmptyCatchBlock">
      <message key="catch.block.empty"
        value="빈 catch 블록 금지 → 예외를 처리하거나 주석으로 이유를 설명하세요."/>
    </module>

  </module>

</module>