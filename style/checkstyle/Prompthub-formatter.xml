<?xml version="1.0" encoding="UTF-8"?>
<code_scheme name="PromptHub-Coding-Convention-v1.0" version="173">

  <!--
    PromptHub IntelliJ Formatter 설정
    기준: Naver Java Coding Convention

    적용 방법:
    1. IntelliJ → File → Settings (Mac: IntelliJ IDEA → Preferences)
    2. Editor → Code Style → Java
    3. 오른쪽 톱니바퀴 클릭
    4. Import Scheme → IntelliJ IDEA Code Style XML
    5. 이 파일 선택 → OK
    6. Scheme 에서 PromptHub-Coding-Convention-v1.0 선택

    적용 단축키:
    Windows: Ctrl + Alt + L
    Mac: Option + Command + L
  -->

  <!-- import 순서 설정 -->
  <option name="CLASS_COUNT_TO_USE_IMPORT_ON_DEMAND" value="99"/>
  <!-- 와일드카드 import 사실상 금지 (99개 이상일 때만 허용) -->

  <option name="NAMES_COUNT_TO_USE_IMPORT_ON_DEMAND" value="1"/>
  <!-- static import 는 1개부터 와일드카드 허용 -->

  <option name="IMPORT_LAYOUT_TABLE">
    <value>
      <emptyLine/>
      <package name="" withSubpackages="true" static="true"/>
      <!-- static import 맨 위 -->
      <emptyLine/>
      <package name="java" withSubpackages="true" static="false"/>
      <emptyLine/>
      <package name="javax" withSubpackages="true" static="false"/>
      <emptyLine/>
      <package name="org" withSubpackages="true" static="false"/>
      <emptyLine/>
      <package name="net" withSubpackages="true" static="false"/>
      <emptyLine/>
      <package name="com" withSubpackages="true" static="false"/>
      <emptyLine/>
      <package name="" withSubpackages="true" static="false"/>
      <!-- 각 그룹 사이 빈 줄 자동 삽입 -->
    </value>
  </option>

  <!-- 한 줄 최대 120자 -->
  <option name="RIGHT_MARGIN" value="120"/>

  <!-- Javadoc 자동 포맷 비활성화 -->
  <option name="ENABLE_JAVADOC_FORMATTING" value="false"/>

  <codeStyleSettings language="JAVA">

    <!-- 주석 들여쓰기 맞추기 -->
    <option name="LINE_COMMENT_AT_FIRST_COLUMN" value="false"/>
    <!-- // 주석을 코드에 맞춰 들여쓰기 -->

    <option name="LINE_COMMENT_ADD_SPACE" value="true"/>
    <!-- // 뒤에 공백 추가 → // 주석 (O) //주석 (X) -->

    <option name="KEEP_FIRST_COLUMN_COMMENT" value="false"/>

    <!-- 빈 줄 최대 1줄 -->
    <option name="KEEP_BLANK_LINES_IN_DECLARATIONS" value="1"/>
    <option name="KEEP_BLANK_LINES_IN_CODE" value="1"/>
    <option name="KEEP_BLANK_LINES_BEFORE_RBRACE" value="1"/>

    <!-- if/for 한 줄이어도 중괄호 강제 -->
    <option name="KEEP_CONTROL_STATEMENT_IN_ONE_LINE" value="false"/>

    <!-- 파라미터 정렬 안함 -->
    <option name="ALIGN_MULTILINE_PARAMETERS" value="false"/>

    <!-- 캐스팅 후 공백 없음 → (String)value -->
    <option name="SPACE_AFTER_TYPE_CAST" value="false"/>

    <!-- 배열 초기화 전 공백 → new int[] {0, 1} -->
    <option name="SPACE_BEFORE_ARRAY_INITIALIZER_LBRACE" value="true"/>

    <!-- 줄바꿈 규칙 -->
    <option name="CALL_PARAMETERS_WRAP" value="1"/>
    <!-- 메서드 호출 파라미터 줄바꿈 허용 -->

    <option name="METHOD_PARAMETERS_WRAP" value="1"/>
    <!-- 메서드 선언 파라미터 줄바꿈 허용 -->

    <option name="METHOD_CALL_CHAIN_WRAP" value="5"/>
    <!--
      메서드 체이닝 줄바꿈
      user.getName()
          .toLowerCase()  ← 이렇게
    -->

    <option name="BINARY_OPERATION_SIGN_ON_NEXT_LINE" value="true"/>
    <!--
      이항 연산자 다음 줄 앞에
      int result = a
          + b  ← 이렇게
          + c
    -->

    <!-- 들여쓰기 -->
    <indentOptions>
      <option name="USE_TAB_CHARACTER" value="true"/>
      <!-- 탭 사용 (스페이스 X) -->

      <option name="CONTINUATION_INDENT_SIZE" value="4"/>
      <!-- 줄바꿈 후 추가 들여쓰기 4칸 -->
    </indentOptions>

  </codeStyleSettings>

</code_scheme>