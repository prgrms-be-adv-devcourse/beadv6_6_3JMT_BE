# =============================================================
# PromptHub — 루트 환경변수 템플릿
# EC2에 이 파일을 .env로 복사한 뒤 값을 채워서 사용한다.
# 사용법: docker compose --env-file .env up -d --build
# =============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── 서비스별 DB 계정 패스워드 (ADR-0002) ───────────────────────
# docker-entrypoint-initdb.d/01-init-schemas-and-roles.sh에서 사용됨.
# 운영 환경에서는 강력한 패스워드로 설정할 것.
USER_SERVICE_PASSWORD=
PRODUCT_SERVICE_PASSWORD=
ORDER_SERVICE_PASSWORD=
PAYMENT_SERVICE_PASSWORD=
SETTLEMENT_SERVICE_PASSWORD=

# ── JWT (RSA — PEM 한 줄 형식, \n으로 개행 이스케이프) ────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Toss Payments ────────────────────────────────────────────
TOSS_SECRET_KEY=
TOSS_TEST_MODE=false

# ── AWS S3 ───────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
