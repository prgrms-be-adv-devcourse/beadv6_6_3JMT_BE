# =============================================================
# PromptHub — 루트 환경변수 템플릿
# EC2에 이 파일을 .env로 복사한 뒤 값을 채워서 사용한다.
# 사용법: docker compose --env-file .env up -d --build
# =============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── JWT (RSA — PEM 한 줄 형식, \n으로 개행 이스케이프) ────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Toss Payments ────────────────────────────────────────────
TOSS_SECRET_KEY=
TOSS_TEST_MODE=false

# ── AWS S3 ───────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=
